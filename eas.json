{
    "cli": {
        "version": ">= 18.1.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle",
                "gradleCommand": ":app:bundleRelease"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "production",
                "releaseStatus": "completed"
            }
        }
    }
}